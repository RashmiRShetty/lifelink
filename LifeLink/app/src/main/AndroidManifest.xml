<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.lifelink">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/lifelink"
        android:label="@string/app_name"
        android:roundIcon="@drawable/dash_inactive"
        android:supportsRtl="true"
        android:theme="@style/Theme.LifeLink"
        tools:targetApi="31">
        <activity
            android:name=".EmergencyRequestActivity"
            android:exported="false" />
        <activity
            android:name=".NormalRequestActivity"
            android:exported="false" />
        <activity
            android:name=".RequestTypeActivity"
            android:exported="false" /> <!-- ✅ Splash is the launcher with exported=true -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".DonorProfileActivity" />
        <activity android:name=".LoginActivity" />
        <activity android:name=".RegisterActivity" />
        <activity android:name=".MainActivity" />
        <activity android:name=".RoleSelectionActivity" />
        <activity android:name=".DonorHomeActivity" />
        <activity android:name=".ForgotPasswordActivity" />
        <activity android:name=".RecipientHomeActivity" />
        <activity android:name=".DonateNowActivity" />
        <activity android:name=".DonationHistoryActivity" />
        <activity android:name=".CreateProfileActivity" />
        <activity android:name=".ViewProfileActivity" />
        <activity android:name=".NearbyRequestsActivity" />
        <activity android:name=".RequestBloodActivity" />
        <activity android:name=".RequestStatusActivity" />
        <activity android:name=".NearbyBloodBanksActivity" />
        <activity android:name=".DonationTipsActivity" />
        <activity android:name=".EmergencyContactActivity" />
    </application>

</manifest>