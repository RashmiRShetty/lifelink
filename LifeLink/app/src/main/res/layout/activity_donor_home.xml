<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ffffff">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/img"
            android:layout_marginTop="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Donor!"
            android:textColor="#e53935"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnDonateNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🩸 Donate Now"
            android:textColor="#fff"
            android:backgroundTint="#e53935"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnDonationHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📜 View Donation History"
            android:textColor="#e53935"
            android:backgroundTint="#f5f5f5"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧾 View My Profile"
            android:textColor="#e53935"
            android:backgroundTint="#f5f5f5"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnNearbyRequests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔍 Nearby Blood Requests"
            android:textColor="#e53935"
            android:backgroundTint="#f5f5f5"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnLastDonation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🕒 Last Donation Date"
            android:textColor="#e53935"
            android:backgroundTint="#f5f5f5"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnQuote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❤️ Motivational Quote"
            android:textColor="#e53935"
            android:backgroundTint="#f5f5f5"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❌ Logout"
            android:textColor="#ffffff"
            android:backgroundTint="#616161"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />
    </LinearLayout>
</ScrollView>
