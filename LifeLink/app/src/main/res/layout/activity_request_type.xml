<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Header Image -->
        <ImageView
            android:id="@+id/headerImage"
            android:layout_width="match_parent"
            android:layout_height="180dp"
        android:scaleType="centerCrop"
        android:layout_marginBottom="20dp" />

        <!-- Title -->
        <TextView
            android:id="@+id/textViewWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose Request Type"
            android:textSize="24sp"
            android:textColor="#D32F2F"
            android:textStyle="bold"
            android:layout_marginBottom="30dp" />

        <!-- Normal Request Card -->
        <LinearLayout
            android:id="@+id/cardNormal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg_normal"
            android:padding="16dp"
            android:elevation="6dp"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

            <!-- Replace with your icon -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Normal Request"
                android:textSize="18sp"
                android:textColor="#000"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- Emergency Request Card -->
        <LinearLayout
            android:id="@+id/cardEmergency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg_emergency"
            android:padding="16dp"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emergency Request"
                android:textSize="18sp"
                android:textColor="#FFF"
                android:layout_marginStart="16dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
