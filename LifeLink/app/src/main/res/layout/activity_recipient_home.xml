<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ffffff">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/receipent"
            android:layout_marginTop="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Recipient!"
            android:textColor="#e53935"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnRequestBlood"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Request Blood"
            android:textColor="#fff"
            android:textStyle="bold"
            android:backgroundTint="#e53935"
            android:padding="14dp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnRequestStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Request Status"
            android:textColor="#e53935"
            android:backgroundTint="#f5f5f5"
            android:textStyle="bold"
            android:padding="14dp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnNearbyBanks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nearby Blood Banks"
            android:textColor="#fff"
            android:textStyle="bold"
            android:backgroundTint="#e53935"
            android:padding="14dp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnTips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Donation Tips"
            android:textColor="#e53935"
            android:backgroundTint="#f5f5f5"
            android:textStyle="bold"
            android:padding="14dp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnEmergency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Emergency Contact"
            android:textColor="#fff"
            android:textStyle="bold"
            android:backgroundTint="#e53935"
            android:padding="14dp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textColor="#e53935"
            android:backgroundTint="#f5f5f5"
            android:textStyle="bold"
            android:padding="14dp" />

    </LinearLayout>
</ScrollView>
